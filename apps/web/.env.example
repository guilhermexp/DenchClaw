# ─── Next.js / runtime ────────────────────────────────────────────────────
WATCHPACK_POLLING=true
IRONCLAW_WEB_ENABLE_MCP_CONNECTORS=0
NEXT_PUBLIC_POSTHOG_KEY=phc_***

# ─── Meetings feature (required to record + transcribe) ───────────────────
# Deepgram: speech-to-text (https://console.deepgram.com)
DEEPGRAM_API_KEY=
# Override the default model (nova-3). See https://developers.deepgram.com/docs/models
DEEPGRAM_MODEL=nova-3

# OpenRouter: LLM used to beautify transcripts and name meetings (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Alternatively both can be set via Settings → Meetings AI in the web UI
# (values saved to ~/.denchclaw/denchclaw.json and take precedence over env vars).

# ─── Dench Cloud (optional — enables cloud sync and hosted integrations) ──
DENCH_CLOUD_API_KEY=
# DENCH_API_KEY is a legacy alias for DENCH_CLOUD_API_KEY (still honoured)

# ─── Hermes agent (optional — defaults to local instance) ─────────────────
HERMES_API_URL=http://localhost:21321
HERMES_API_KEY=
